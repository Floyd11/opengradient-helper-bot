[Unit]
Description=OpenGradient Helper Telegram Bot
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/og-helper-bot
ExecStart=/home/ubuntu/og-helper-bot/venv/bin/python bot.py
Restart=always
RestartSec=10
EnvironmentFile=/home/ubuntu/og-helper-bot/.env

[Install]
WantedBy=multi-user.target
